<?php
/**
 * Resolve system settings
 * @var array $options
 * @var xPDOTransport $transport
 */

if (!function_exists('setOption')) {
    function setOption(modX $modx, $key, $value, $namespace, $clearCache = true)
    {
        if (empty(trim($key))) return false;

        if (!$setting = $modx->getObject('modSystemSetting', $key)) {
            $setting = $modx->newObject('modSystemSetting');
            $setting->set('key', $key);
            $setting->set('namespace', $namespace);
        }

        $val = is_array($value) ? $modx->toJSON($value) : $value;
        $setting->set('value', $val);

        if ($setting->save()) {
            $modx->setOption($key, $value);
            if ($clearCache) {
                $modx->cacheManager->refresh(array('system_settings' => array()));
            }
            return true;
        }
        return false;
    }
}

if (!function_exists('setDefaultSettings')) {
    /**
     * @param modX $modx
     * @param array $settings
     * @param string $mode
     * @return void|bool
     */
    function setDefaultSettings(modX $modx, array $settings, $mode = 'import')
    {
        $namespace = 'msimportexport';
        if (empty($settings)) return;
        $key = "msimportexport_{$mode}_default_settings";
        $default = $modx->getOption($key, null, '{}', true);
        if (is_string($default)) {
            $default = $modx->fromJSON($default);
        }
        if (!$default) $default = array();
        $default = array_merge($settings, $default);

        return setOption($modx, $key, $default, $namespace);
    }
}

$importDefaultSettings = array();
$exportDefaultSettings = array(
    'ym_offer_type' => 'simple',
    'ym_default_currency' => 'RUB',
    'ym_rate_currency' => 'CBRF',
    'ym_currencies' => 'RUB',
    'ym_delivery_default' => 0,
    'ym_pickup_default' => 1,
    'ym_store_default' => 1,
    'ym_available_default' => 1,
    'ym_description_fields' => 'description,introtext',
    'ym_desc_allowed_tags' => '<p>,<strong>,<i>,<u>',
    'ym_include_saleprice' => 0,
    'ym_only_saleprice_price' => 0,
    'ym_include_optionsprice2' => 0,
    'ym_multicategories' => 0,
);

if ($object->xpdo) {
    switch ($options[xPDOTransport::PACKAGE_ACTION]) {
        case xPDOTransport::ACTION_INSTALL:
        case xPDOTransport::ACTION_UPGRADE:
            /** @var modX $modx */
            $modx =& $object->xpdo;
            setDefaultSettings($modx, $importDefaultSettings);
            setDefaultSettings($modx, $exportDefaultSettings, 'export');
            break;
        case xPDOTransport::ACTION_UNINSTALL:
            break;

    }
}

return true;